{
  "name": "github-agent-orchestrator",
  "version": "0.1.0",
  "description": "AI agent that monitors GitHub issues across multiple repositories and automatically creates PRs",
  "main": "dist/index.js",
  "bin": {
    "agent-orchestrator": "dist/cli.js",
    "agent-orchestrator-web": "dist/web/server.js"
  },
  "scripts": {
    "build": "tsc",
    "start": "node dist/cli.js web",
    "start:web": "node dist/web/server.js",
    "dev": "ts-node src/index.ts",
    "dev:web": "ts-node src/web/server.ts",
    "cli": "ts-node src/cli.ts",
    "test": "jest",
    "lint": "eslint src/**/*.ts"
  },
  "keywords": [
    "github",
    "agent",
    "automation",
    "pr",
    "issues",
    "orchestrator"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@actions/core": "^1.10.1",
    "@actions/github": "^6.0.0",
    "@octokit/action": "^6.1.0",
    "@octokit/rest": "^20.1.1",
    "chalk": "^4.1.2",
    "cli-table3": "^0.6.5",
    "commander": "^12.1.0",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "inquirer": "^8.2.6",
    "ora": "^5.4.1",
    "simple-git": "^3.25.0",
    "uuid": "^9.0.1"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/inquirer": "^8.2.10",
    "@types/jest": "^29.5.12",
    "@types/node": "^20.14.2",
    "@types/uuid": "^9.0.8",
    "@typescript-eslint/eslint-plugin": "^7.13.0",
    "@typescript-eslint/parser": "^7.13.0",
    "eslint": "^8.57.0",
    "jest": "^29.7.0",
    "ts-jest": "^29.1.4",
    "ts-node": "^10.9.2",
    "typescript": "^5.4.5"
  }
}
